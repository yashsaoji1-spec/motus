rules_version = '2';

// PhalanX — Firestore Security Rules
// Simplified: any authenticated user can read/write all collections.
// Tighter per-collection rules can be re-added once login is confirmed working.

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
