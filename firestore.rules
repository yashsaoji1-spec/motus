rules_version = '2';

// Motus — Firestore Security Rules
// Per-collection rules enforcing role-based access.
// Roles: patient, therapist, therapist_pending, admin (stored in users/{email}.role)

service cloud.firestore {
  match /databases/{database}/documents {

    // -- Helpers --

    function isAuth() {
      return request.auth != null;
    }

    function myEmail() {
      return request.auth.token.email;
    }

    function myRole() {
      return get(/databases/$(database)/documents/users/$(myEmail())).data.role;
    }

    function isTherapist() {
      return myRole() == 'therapist';
    }

    function isPatient() {
      return myRole() == 'patient';
    }

    function isAdmin() {
      return myRole() == 'admin';
    }

    // True if the current therapist has this patient in their connections doc.
    function connectedToPatient(patientEmail) {
      return exists(/databases/$(database)/documents/connections/$(myEmail())) &&
        patientEmail in get(/databases/$(database)/documents/connections/$(myEmail())).data.patients;
    }

    // True if any therapist connected to this patient is the current user.
    // Used for reads keyed by patientEmail when the caller is a therapist.
    function therapistCanAccessPatient(patientEmail) {
      return isTherapist() && connectedToPatient(patientEmail);
    }

    function isClinicOwner(clinicId) {
      return get(/databases/$(database)/documents/clinics/$(clinicId)).data.ownerEmail == myEmail();
    }
    function inClinic(clinicId) {
      return myEmail() in get(/databases/$(database)/documents/clinics/$(clinicId)).data.therapists;
    }


    // -- users/{email} --
    // Scoped reads: own doc, admin, connected parties, or therapist-profile discovery.
    // Patients can read any therapist doc (needed for connect-by-code and name display).
    // Patients cannot read other patients' docs.
    match /users/{email} {
      allow read: if isAuth() && (
        myEmail() == email ||
        isAdmin() ||
        (isTherapist() && connectedToPatient(email)) ||
        // Patients read therapist profiles for connect-by-code discovery and name display.
        // query .where('role','==','therapist') satisfies the rule validator.
        (isPatient() && resource.data.role == 'therapist')
      );
      allow write: if isAuth() && (myEmail() == email || isAdmin());
      // Therapist can clear a connected patient's therapistEmail field on disconnect.
      // Must still be connected when this write runs (sequenced before removing from connections).
      allow update: if isAuth() && isTherapist() && connectedToPatient(email) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['therapistEmail']) &&
        !('therapistEmail' in request.resource.data);
    }


    // -- connections/{therapistEmail} --
    // Therapist manages their own connection list.
    // Patients can update (but not create/delete) to add themselves via connect code.
    match /connections/{therapistEmail} {
      allow read: if isAuth() && (myEmail() == therapistEmail || isAdmin() || myEmail() in resource.data.patients);
      allow create: if isAuth() && (
        myEmail() == therapistEmail ||
        isAdmin() ||
        // Patient bootstraps the doc when connecting to their first therapist
        (isPatient() && request.resource.data.patients.hasOnly([myEmail()]))
      );
      allow delete: if isAuth() && (myEmail() == therapistEmail || isAdmin());
      // Patients may only append their own email to the patients array — no other mutations.
      allow update: if isAuth() && (
        myEmail() == therapistEmail ||
        isAdmin() ||
        (isPatient() &&
          request.resource.data.patients.hasAll(resource.data.patients) &&
          request.resource.data.patients.hasOnly(resource.data.patients.concat([myEmail()])))
      );
    }


    // -- protocols/{patientEmail} --
    // Patient reads their own; therapist reads+writes for connected patients.
    match /protocols/{patientEmail} {
      allow read: if isAuth() && (
        myEmail() == patientEmail ||
        therapistCanAccessPatient(patientEmail) ||
        isAdmin()
      );
      allow write: if isAuth() && (
        therapistCanAccessPatient(patientEmail) ||
        isAdmin()
      );
    }


    // -- sessions (auto-id) --
    // Patient creates + updates their own sessions (two-step: create then update with videoUrl).
    // Therapist reads + updates sessions for connected patients.
    match /sessions/{sessionId} {
      // Split into separate rules so Firestore's query validator can evaluate each independently.
      // Patient self-read has no get() calls, letting the query constraint prove access.
      allow read: if isAuth() && myEmail() == resource.data.patientEmail;
      allow read: if isAuth() && isTherapist() && connectedToPatient(resource.data.patientEmail);
      allow read: if isAuth() && isAdmin();
      allow create: if isAuth() && (
        myEmail() == request.resource.data.patientEmail ||
        isAdmin()
      ) && (!('notes' in request.resource.data) || request.resource.data.notes.size() <= 1000);
      allow update: if isAuth() && (
        myEmail() == resource.data.patientEmail ||
        (isTherapist() && connectedToPatient(resource.data.patientEmail)) ||
        isAdmin()
      );
      allow delete: if isAuth() && isAdmin();
    }


    // -- calibration/{patientEmail} --
    // Patient reads their own; therapist reads+writes for connected patients.
    match /calibration/{patientEmail} {
      allow read: if isAuth() && (
        myEmail() == patientEmail ||
        therapistCanAccessPatient(patientEmail) ||
        isAdmin()
      );
      allow write: if isAuth() && (
        therapistCanAccessPatient(patientEmail) ||
        isAdmin()
      );
    }


    // -- clinicalNotes/{patientEmail} --
    // Therapist-only notes about a patient. Patients cannot read.
    match /clinicalNotes/{patientEmail} {
      allow read: if isAuth() && (
        therapistCanAccessPatient(patientEmail) ||
        isAdmin()
      );
      allow write: if isAuth() && (
        therapistCanAccessPatient(patientEmail) ||
        isAdmin()
      );
    }


    // -- messageThreads/{threadId} -- Thread metadata (archived status, disconnect timestamp)
    // threadId = sorted(email1, email2).join(':')
    match /messageThreads/{threadId} {
      allow read: if isAuth() && myEmail() in resource.data.participants;
      allow create: if isAuth() && myEmail() in request.resource.data.participants;
      allow update: if isAuth() && myEmail() in resource.data.participants;
      allow delete: if isAuth() && isAdmin();
    }


    // -- messages (auto-id, fields: participants: [email, email], threadId: string) --
    // Only participants can read/write their thread.
    // New messages blocked if the messageThreads doc is archived.
    match /messages/{messageId} {
      allow read: if isAuth() && (
        myEmail() in resource.data.participants ||
        myEmail() == resource.data.to ||
        myEmail() == resource.data.from ||
        isAdmin()
      );
      allow create: if isAuth() && myEmail() in request.resource.data.participants
        && (!('text' in request.resource.data) || request.resource.data.text.size() <= 2000)
        && (
          !('threadId' in request.resource.data) ||
          !exists(/databases/$(database)/documents/messageThreads/$(request.resource.data.threadId)) ||
          get(/databases/$(database)/documents/messageThreads/$(request.resource.data.threadId)).data.archived != true
        );
      allow update: if isAuth() && myEmail() in resource.data.participants;
      allow delete: if isAuth() && isAdmin();
    }


    // -- jointTracking/{patientEmail} --
    // Patient reads their own; therapist reads+writes for connected patients.
    match /jointTracking/{patientEmail} {
      allow read: if isAuth() && (
        myEmail() == patientEmail ||
        therapistCanAccessPatient(patientEmail) ||
        isAdmin()
      );
      allow write: if isAuth() && (
        therapistCanAccessPatient(patientEmail) ||
        isAdmin()
      );
    }


    // -- customExercises (auto-id, field: createdBy) --
    // Any auth user reads (exercises are loaded into the protocol catalog for all therapists).
    // Therapists create their own; only creator or admin can modify/delete.
    match /customExercises/{exerciseId} {
      allow read: if isAuth();
      allow create: if isAuth() && isTherapist() &&
        request.resource.data.createdBy == myEmail();
      allow update, delete: if isAuth() && (
        (isTherapist() && resource.data.createdBy == myEmail()) ||
        isAdmin()
      );
    }


    // -- trainingChunks (auto-id) -- ML training samples
    // Therapist-only read/write. No patient access needed.
    match /trainingChunks/{chunkId} {
      allow read, write: if isAuth() && (isTherapist() || isAdmin());
    }


    // -- trainingMeta/{joint-hand} -- ML coverage metadata
    match /trainingMeta/{jointHand} {
      allow read, write: if isAuth() && (isTherapist() || isAdmin());
    }


    // -- mlModels/{joint-hand} -- Trained angle models
    // Patients read during live sessions; therapists write.
    match /mlModels/{jointHand} {
      allow read: if isAuth();
      allow write: if isAuth() && (isTherapist() || isAdmin());
    }


    // -- clinics/{clinicId} --
    // Any therapist can read (needed for join-by-code query).
    // Any therapist can create if they set themselves as owner.
    // Owner can update any field; any therapist can add/remove their own email from therapists.
    match /clinics/{clinicId} {
      allow read: if isAuth() && (isTherapist() || isAdmin());
      allow create: if isAuth() && isTherapist() &&
        request.resource.data.ownerEmail == myEmail() &&
        myEmail() in request.resource.data.therapists;
      allow update: if isAuth() && (
        isAdmin() ||
        isClinicOwner(clinicId) ||
        (isTherapist() && (
          // joining: add own email
          (request.resource.data.therapists.hasAll(resource.data.therapists) &&
           request.resource.data.therapists.hasOnly(resource.data.therapists.concat([myEmail()]))) ||
          // leaving: remove own email
          (resource.data.therapists.hasAll(request.resource.data.therapists) &&
           resource.data.therapists.hasOnly(request.resource.data.therapists.concat([myEmail()])))
        ))
      );
      allow delete: if isAuth() && (isClinicOwner(clinicId) || isAdmin());
    }


    // -- clinicInvites/{inviteId} --
    // Invitee or inviter can read. Only clinic owner can create. Invitee can update status.
    match /clinicInvites/{inviteId} {
      allow read: if isAuth() && (
        resource.data.inviteeEmail == myEmail() ||
        resource.data.invitedBy == myEmail() ||
        isAdmin()
      );
      allow create: if isAuth() && isTherapist() &&
        request.resource.data.invitedBy == myEmail() &&
        isClinicOwner(request.resource.data.clinicId);
      allow update: if isAuth() && (
        (resource.data.inviteeEmail == myEmail()) ||
        isAdmin()
      );
      allow delete: if isAuth() && isAdmin();
    }


    // -- therapistLibrary/{therapistEmail} --
    // Each therapist owns their own library document.
    match /therapistLibrary/{therapistEmail} {
      allow read, write: if isAuth() && myEmail() == therapistEmail;
    }


    // -- clinicLibrary/{clinicId} --
    // Only clinic members can read or write.
    match /clinicLibrary/{clinicId} {
      allow read: if isAuth() && (inClinic(clinicId) || isAdmin());
      allow write: if isAuth() && (inClinic(clinicId) || isAdmin());
    }


    // -- auditLog/{entryId} -- HIPAA §164.312(b) audit trail
    // Append-only from authenticated clients. No client reads, updates, or deletes.
    // Review via Firebase Console or Cloud Functions only.
    match /auditLog/{entryId} {
      allow create: if isAuth();
      allow read, update, delete: if false;
    }

  }
}
