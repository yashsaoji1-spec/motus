rules_version = '2';

// Motus — Firestore Security Rules
// Per-collection rules enforcing role-based access.
// Roles: patient, therapist, therapist_pending, admin (stored in users/{email}.role)

service cloud.firestore {
  match /databases/{database}/documents {

    // -- Helpers --

    function isAuth() {
      return request.auth != null;
    }

    function myEmail() {
      return request.auth.token.email;
    }

    function myRole() {
      return get(/databases/$(database)/documents/users/$(myEmail())).data.role;
    }

    function isTherapist() {
      return myRole() == 'therapist';
    }

    function isPatient() {
      return myRole() == 'patient';
    }

    function isAdmin() {
      return myRole() == 'admin';
    }

    // True once the patient has accepted consent. Server-side floor behind the
    // client consent gate — blocks PHI writes from a patient who never consented.
    // (Per-version re-prompting is enforced client-side against NPP_VERSION.)
    function hasConsented() {
      return get(/databases/$(database)/documents/users/$(myEmail())).data.consentGiven == true;
    }

    // True if the current therapist has this patient in their connections doc.
    function connectedToPatient(patientEmail) {
      return exists(/databases/$(database)/documents/connections/$(myEmail())) &&
        patientEmail in get(/databases/$(database)/documents/connections/$(myEmail())).data.patients;
    }

    // True if any therapist connected to this patient is the current user.
    // Used for reads keyed by patientEmail when the caller is a therapist.
    function therapistCanAccessPatient(patientEmail) {
      return isTherapist() && connectedToPatient(patientEmail);
    }

    // True if the caller's own users doc names this therapist as their connected
    // therapist. Lets a patient read exactly one therapist profile (their own).
    // Callers must ALSO check resource.data.role == 'therapist': therapistEmail
    // is self-writable, so without the role check a patient could point it at
    // any user's email and read that doc.
    function isMyTherapist(therapistEmail) {
      return get(/databases/$(database)/documents/users/$(myEmail())).data.therapistEmail == therapistEmail;
    }

    // Canonical thread id for a 2-element participants list: emails sorted
    // ascending, joined with ':'. Matches getThreadId() in the client.
    function canonicalThreadId(participants) {
      return participants[0] < participants[1]
        ? participants[0] + ':' + participants[1]
        : participants[1] + ':' + participants[0];
    }

    function isClinicOwner(clinicId) {
      return get(/databases/$(database)/documents/clinics/$(clinicId)).data.ownerEmail == myEmail();
    }
    function inClinic(clinicId) {
      return myEmail() in get(/databases/$(database)/documents/clinics/$(clinicId)).data.therapists;
    }


    // -- users/{email} --
    // Scoped reads: own doc, admin, or connected parties only.
    // Patients cannot read other patients' docs, and can read exactly ONE
    // therapist doc: their own connected therapist (for name display).
    // Connect-by-code no longer reads therapist docs — the therapistCodes doc
    // (creatable only by the therapist it names) proves the code is real, and
    // the client fetches the name after the connection is saved.
    match /users/{email} {
      allow read: if isAuth() && (
        myEmail() == email ||
        isAdmin() ||
        (isTherapist() && connectedToPatient(email)) ||
        (isPatient() && resource.data.role == 'therapist' && isMyTherapist(email))
      );
      // Self-signup: role must be 'patient' or 'therapist_pending' — admin can create any role.
      // Prevents a user from granting themselves 'therapist' or 'admin' at account creation.
      allow create: if isAuth() && (
        (myEmail() == email && request.resource.data.role in ['patient', 'therapist_pending']) ||
        isAdmin()
      );
      // Self-update: role is immutable for non-admins — blocks self-promotion to therapist/admin
      // (legitimate self-writes — name, language, demographics, consent, clinicId — never touch role).
      // therapistEmail is also authoritative: it is written only by the connectByCode
      // Cloud Function (admin). A self-write may keep it unchanged or CLEAR it (patient
      // disconnect), but never set/change it — otherwise a patient could point it at any
      // therapist and read that therapist's user doc (isMyTherapist) without a real connection.
      allow update: if isAuth() && (
        (myEmail() == email && request.resource.data.role == resource.data.role &&
          (!('therapistEmail' in request.resource.data) ||
            (('therapistEmail' in resource.data) &&
             request.resource.data.therapistEmail == resource.data.therapistEmail))) ||
        isAdmin()
      );
      allow delete: if isAuth() && (myEmail() == email || isAdmin());
      // Therapist can clear a connected patient's therapistEmail field on disconnect.
      // Must still be connected when this write runs (sequenced before removing from connections).
      allow update: if isAuth() && isTherapist() && connectedToPatient(email) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['therapistEmail']) &&
        !('therapistEmail' in request.resource.data);
    }


    // -- connections/{therapistEmail} --
    // Therapist manages their own connection list. The connectByCode Cloud
    // Function (admin) adds a patient on connect, so there is no patient CREATE
    // or add-self branch here — a patient can only REMOVE themselves (disconnect).
    // No patient reads: the doc is the therapist's full patient roster, and exposing
    // it would leak every co-patient's email (PHI-adjacent — it reveals who is in
    // therapy). A patient's own connection status lives on their users doc.
    match /connections/{therapistEmail} {
      allow read: if isAuth() && (myEmail() == therapistEmail || isAdmin());
      allow create: if isAuth() && (myEmail() == therapistEmail || isAdmin());
      allow delete: if isAuth() && (myEmail() == therapistEmail || isAdmin());
      // Patient-initiated disconnect (disconnectFromTherapist) arrayRemoves the
      // caller from their therapist's roster: a patient may touch only the patients
      // key and only to remove their OWN email — never add anyone or remove others.
      // The three clauses together force new == old \ {me}:
      //   - me must be absent from the new list (self actually removed)
      //   - old ⊇ new (nothing added)
      //   - old ⊆ new ∪ {me} (nothing other than me removed)
      allow update: if isAuth() && (
        myEmail() == therapistEmail ||
        isAdmin() ||
        (isPatient() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['patients']) &&
          !(myEmail() in request.resource.data.patients) &&
          resource.data.patients.hasAll(request.resource.data.patients) &&
          resource.data.patients.hasOnly(request.resource.data.patients.concat([myEmail()])))
      );
    }


    // -- protocols/{patientEmail} --
    // Patient reads their own; therapist reads+writes for connected patients.
    match /protocols/{patientEmail} {
      allow read: if isAuth() && (
        myEmail() == patientEmail ||
        therapistCanAccessPatient(patientEmail) ||
        isAdmin()
      );
      allow write: if isAuth() && (
        therapistCanAccessPatient(patientEmail) ||
        isAdmin()
      );
    }


    // -- sessions (auto-id) --
    // Patient creates their own sessions. The only post-creation update is the async
    // video upload (videoUrl + videoExpireAt) — restrict updates to those two fields so
    // core clinical data (reps, pain, date, exerciseType) is immutable after recording.
    match /sessions/{sessionId} {
      // Split into separate rules so Firestore's query validator can evaluate each independently.
      // Patient self-read has no get() calls, letting the query constraint prove access.
      allow read: if isAuth() && myEmail() == resource.data.patientEmail;
      allow read: if isAuth() && isTherapist() && connectedToPatient(resource.data.patientEmail);
      allow read: if isAuth() && isAdmin();
      allow create: if isAuth() && (
        (myEmail() == request.resource.data.patientEmail && hasConsented()) ||
        isAdmin()
      ) && request.resource.data.patientEmail is string
        && (!('notes' in request.resource.data) ||
            (request.resource.data.notes is string && request.resource.data.notes.size() <= 1000));
      // Only videoUrl and videoExpireAt may be updated (async video upload after session is saved).
      // Prevents retroactive modification of reps, pain, date, or other clinical fields.
      // Patients may only update video keys (async upload after save).
      // Therapists connected to the patient may additionally set review/flag
      // fields (D-2) — but never clinical data (reps, pain, date).
      allow update: if isAuth() && (
        isAdmin() ||
        (myEmail() == resource.data.patientEmail &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['videoUrl', 'videoExpireAt'])) ||
        (isTherapist() && connectedToPatient(resource.data.patientEmail) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(
            ['videoUrl', 'videoExpireAt', 'reviewed', 'reviewedBy', 'reviewedAt', 'flagged', 'flaggedAt']))
      );
      allow delete: if isAuth() && isAdmin();
    }


    // -- calibration/{patientEmail} --
    // Patient reads their own; therapist reads+writes for connected patients.
    match /calibration/{patientEmail} {
      allow read: if isAuth() && (
        myEmail() == patientEmail ||
        therapistCanAccessPatient(patientEmail) ||
        isAdmin()
      );
      allow write: if isAuth() && (
        therapistCanAccessPatient(patientEmail) ||
        isAdmin()
      );
    }


    // -- clinicalNotes/{patientEmail} --
    // Therapist-only notes about a patient. Patients cannot read.
    // html is bounded (well above the UI's practical size) to cap storage abuse
    // from a compromised therapist account. Delete stays separate — delete has
    // no request.resource, so shape checks on `write` would break it.
    match /clinicalNotes/{patientEmail} {
      allow read: if isAuth() && (
        therapistCanAccessPatient(patientEmail) ||
        isAdmin()
      );
      allow create, update: if isAuth() && (
        therapistCanAccessPatient(patientEmail) ||
        isAdmin()
      ) && (!('html' in request.resource.data) ||
            (request.resource.data.html is string && request.resource.data.html.size() <= 50000));
      allow delete: if isAuth() && (
        therapistCanAccessPatient(patientEmail) ||
        isAdmin()
      );
    }


    // -- messageThreads/{threadId} -- Thread metadata (archived status, disconnect timestamp)
    // threadId = sorted(email1, email2).join(':')
    match /messageThreads/{threadId} {
      allow read: if isAuth() && myEmail() in resource.data.participants;
      // The doc id must be the canonical id OF ITS OWN participants (which must
      // include the caller). Otherwise anyone could squat messageThreads/{a:b}
      // for two OTHER users — with archived:true — and block their messaging.
      allow create: if isAuth() &&
        request.resource.data.participants is list &&
        request.resource.data.participants.size() == 2 &&
        myEmail() in request.resource.data.participants &&
        threadId == canonicalThreadId(request.resource.data.participants);
      // Only the disconnect flow writes here — restrict to archived + disconnectedAt so
      // participants can't modify each other's email addresses or hijack the thread.
      // diff() only lists keys whose values actually changed, so the disconnect flow's
      // set({merge:true}) writing participants with the same value passes without listing it.
      allow update: if isAuth() && myEmail() in resource.data.participants &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['archived', 'disconnectedAt']);
      allow delete: if isAuth() && isAdmin();
    }


    // -- messages (auto-id, fields: participants: [email, email], threadId: string) --
    // Only participants can read/write their thread.
    // New messages blocked if the messageThreads doc is archived.
    match /messages/{messageId} {
      allow read: if isAuth() && (
        myEmail() in resource.data.participants ||
        myEmail() == resource.data.to ||
        myEmail() == resource.data.from ||
        isAdmin()
      );
      // from must be the caller: without this pin, any participant could forge a
      // message that renders as sent BY the other party (sender spoofing).
      allow create: if isAuth()
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && myEmail() in request.resource.data.participants
        && request.resource.data.from == myEmail()
        && request.resource.data.to is string
        && (!('text' in request.resource.data) ||
            (request.resource.data.text is string && request.resource.data.text.size() <= 2000))
        // threadId is REQUIRED and must be the canonical id for the participants —
        // an optional or free-form threadId would let a sender dodge the
        // archived-thread block below by omitting it or pointing elsewhere.
        && request.resource.data.threadId == canonicalThreadId(request.resource.data.participants)
        && (
          !exists(/databases/$(database)/documents/messageThreads/$(request.resource.data.threadId)) ||
          get(/databases/$(database)/documents/messageThreads/$(request.resource.data.threadId)).data.archived != true
        );
      // Only the recipient can update a message, and only to flip 'read' to true —
      // blocks tampering with text/sender/timestamp/participants of existing messages.
      allow update: if isAuth() && myEmail() == resource.data.to &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']) &&
        request.resource.data.read == true;
      allow delete: if isAuth() && isAdmin();
    }


    // -- jointTracking/{patientEmail} --
    // Patient reads their own; therapist reads+writes for connected patients.
    match /jointTracking/{patientEmail} {
      allow read: if isAuth() && (
        myEmail() == patientEmail ||
        therapistCanAccessPatient(patientEmail) ||
        isAdmin()
      );
      allow write: if isAuth() && (
        therapistCanAccessPatient(patientEmail) ||
        isAdmin()
      );
    }


    // -- customExercises (auto-id, field: createdBy) --
    // Any auth user reads (exercises are loaded into the protocol catalog for all therapists).
    // Therapists create their own; only creator or admin can modify/delete.
    match /customExercises/{exerciseId} {
      allow read: if isAuth();
      allow create: if isAuth() && isTherapist() &&
        request.resource.data.createdBy == myEmail();
      allow update, delete: if isAuth() && (
        (isTherapist() && resource.data.createdBy == myEmail()) ||
        isAdmin()
      );
    }


    // -- trainingChunks (auto-id) -- ML training samples
    // Therapist-only read/write. No patient access needed.
    match /trainingChunks/{chunkId} {
      allow read, write: if isAuth() && (isTherapist() || isAdmin());
    }


    // -- trainingMeta/{joint-hand} -- ML coverage metadata
    match /trainingMeta/{jointHand} {
      allow read, write: if isAuth() && (isTherapist() || isAdmin());
    }


    // -- mlModels/{joint-hand} -- Trained angle models
    // Patients read during live sessions; therapists write.
    match /mlModels/{jointHand} {
      allow read: if isAuth();
      allow write: if isAuth() && (isTherapist() || isAdmin());
    }


    // -- clinics/{clinicId} --
    // Any therapist can read (needed for join-by-code query).
    // Any therapist can create if they set themselves as owner.
    // Owner can update any field; any therapist can add/remove their own email from therapists.
    match /clinics/{clinicId} {
      allow read: if isAuth() && (isTherapist() || isAdmin());
      allow create: if isAuth() && isTherapist() &&
        request.resource.data.ownerEmail == myEmail() &&
        myEmail() in request.resource.data.therapists;
      allow update: if isAuth() && (
        isAdmin() ||
        isClinicOwner(clinicId) ||
        // Non-owner therapists may only join/leave: the ONLY field they may touch is
        // `therapists`. Without this diff() guard a member could set ownerEmail=self in
        // the same write and escalate to clinic owner (privilege escalation).
        (isTherapist() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['therapists']) && (
          // joining: add own email
          (request.resource.data.therapists.hasAll(resource.data.therapists) &&
           request.resource.data.therapists.hasOnly(resource.data.therapists.concat([myEmail()]))) ||
          // leaving: remove own email
          (resource.data.therapists.hasAll(request.resource.data.therapists) &&
           resource.data.therapists.hasOnly(request.resource.data.therapists.concat([myEmail()])))
        ))
      );
      allow delete: if isAuth() && (isClinicOwner(clinicId) || isAdmin());
    }


    // -- clinicInvites/{inviteId} --
    // Invitee or inviter can read. Only clinic owner can create. Invitee can update status.
    match /clinicInvites/{inviteId} {
      allow read: if isAuth() && (
        resource.data.inviteeEmail == myEmail() ||
        resource.data.invitedBy == myEmail() ||
        isAdmin()
      );
      allow create: if isAuth() && isTherapist() &&
        request.resource.data.invitedBy == myEmail() &&
        isClinicOwner(request.resource.data.clinicId);
      // Invitee can only flip status — not change clinicId, invitedBy, or any other field.
      // Without this, an invitee could change clinicId before accepting to join a different clinic.
      allow update: if isAuth() && (
        (resource.data.inviteeEmail == myEmail() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])) ||
        isAdmin()
      );
      allow delete: if isAuth() && isAdmin();
    }


    // -- therapistLibrary/{therapistEmail} --
    // Each therapist owns their own library document.
    match /therapistLibrary/{therapistEmail} {
      allow read, write: if isAuth() && myEmail() == therapistEmail;
    }


    // -- clinicLibrary/{clinicId} --
    // Only clinic members can read or write.
    match /clinicLibrary/{clinicId} {
      allow read: if isAuth() && (inClinic(clinicId) || isAdmin());
      allow write: if isAuth() && (inClinic(clinicId) || isAdmin());
    }


    // -- therapistCodes/{code} -- maps clinic codes to therapist emails
    // Therapists create/read their own code; patients read any code (for connect-by-code).
    // get (direct read by known code) only — NOT list. The connect-by-code flow
    // reads a single doc by its exact code; allowing list would let any patient
    // enumerate the whole collection and harvest every therapist's email.
    match /therapistCodes/{code} {
      allow get: if isAuth();
      // keys().hasOnly(['email']): the code doc is readable by every signed-in
      // user, so no other data may ride along in it.
      allow create: if isAuth() && isTherapist() &&
        request.resource.data.keys().hasOnly(['email']) &&
        request.resource.data.email == myEmail();
      // A therapist may only overwrite/delete a code doc that already points to
      // themselves. The blanket `write` previously let any therapist overwrite an
      // EXISTING code owned by another therapist, hijacking their connect-by-code
      // mapping so patients connect to the attacker instead (connection hijack).
      allow update: if isAuth() && isTherapist() &&
        resource.data.email == myEmail() &&
        request.resource.data.keys().hasOnly(['email']) &&
        request.resource.data.email == myEmail();
      allow delete: if isAuth() && isTherapist() && resource.data.email == myEmail();
    }


    // -- auditLog/{entryId} -- HIPAA §164.312(b) audit trail
    // Append-only from authenticated clients. No client reads, updates, or deletes.
    // actorId must be the caller's own UID so an entry can't be forged under
    // another actor. Review via Firebase Console or Cloud Functions only.
    match /auditLog/{entryId} {
      allow create: if isAuth() && request.resource.data.actorId == request.auth.uid;
      allow read, update, delete: if false;
    }

  }
}
